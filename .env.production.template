# AI Team OS Phase 13 production deployment template.
# Copy to /etc/ai-team-os/ai-team-os.env, replace every placeholder outside Git,
# then restrict the file to root:root mode 0600. Never commit the populated file.

NODE_ENV="production"
HOSTNAME="0.0.0.0"
PORT="3000"
TEAM_OS_ENVIRONMENT="production"

# Public HTTPS origin. Replace the example domain before deployment.
NEXT_PUBLIC_APP_URL="https://team-os.example.com"
# Trusted existing knowledge-service HTTPS origin used only by server-to-server
# AI Brain publish/optimize calls. It must not equal the public Team OS origin.
APP_URL="https://knowledge.example.com"

# Alibaba Cloud RDS PostgreSQL is the recommended production topology. Runtime
# may use a pooler; migrations must use a direct endpoint through DIRECT_URL.
DATABASE_URL="postgresql://APP_USER:APP_PASSWORD@RDS_HOST:5432/APP_DATABASE?sslmode=require&schema=public"
DIRECT_URL="postgresql://MIGRATION_USER:MIGRATION_PASSWORD@RDS_HOST:5432/APP_DATABASE?sslmode=require&schema=public"
# Required dedicated backup account in libpq URL form. backup.sh deliberately
# refuses to fall back to the runtime or migration credentials.
BACKUP_DATABASE_URL="postgresql://BACKUP_USER:BACKUP_PASSWORD@RDS_HOST:5432/APP_DATABASE?sslmode=require"

# Only used when the opt-in Compose database profile is explicitly selected.
POSTGRES_DB="ai_team_os"
POSTGRES_USER="ai_team_os"
POSTGRES_PASSWORD=""
ENABLE_BUNDLED_POSTGRES="false"

# Redis is reserved for future shared cache/queue work. The current application
# does not consume REDIS_URL, so leave the cache profile disabled in production.
REDIS_URL=""
REDIS_PASSWORD=""
ENABLE_BUNDLED_REDIS="false"

AI_PROVIDER="qwen"
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# Generate independent high-entropy values. ENCRYPTION_KEY must be a 64-digit
# hexadecimal value or a 32-byte base64url value.
SESSION_SECRET=""
ENCRYPTION_KEY=""
TEAM_OS_INTEGRATION_ENCRYPTION_KEY=""

# Compatibility variables required only by the root monolith's existing auth,
# license, attachment, or scheduled-job code. Do not reuse values between keys.
LICENSE_SECRET=""
ADMIN_TOKEN=""
CRON_SECRET=""
NETLIFY_BLOBS_SITE_ID=""
NETLIFY_BLOBS_TOKEN=""

# Independent Team OS Docker service. Port 3022 remains loopback-only and does
# not replace the existing AI knowledge application process.
TEAM_OS_IMAGE="ai-team-os:1.0.0"
TEAM_OS_BIND_ADDRESS="127.0.0.1"
TEAM_OS_PORT="3022"
WEB_RELEASE_SHA="unreleased"

# Safe release-directory deployment controls.
DEPLOY_SOURCE_MODE="git"
DEPLOY_REPOSITORY_URL=""
DEPLOY_RELEASE_REF=""
DEPLOY_SOURCE_ARCHIVE=""
DEPLOY_RELEASE_SHA=""
DEPLOY_SOURCE_ARCHIVE_SHA256=""
DEPLOY_BASE_DIR="/opt/ai-team-os"
DEPLOY_STATE_DIR="/var/lib/ai-team-os"
DEPLOY_BACKUP_DIR="/var/backups/ai-team-os"
DEPLOY_LOCK_FILE="/run/ai-team-os/deploy.lock"
BACKUP_LOCK_FILE="/run/ai-team-os/backup.lock"
BACKUP_RETENTION_DAYS="14"
PG_BACKUP_IMAGE="postgres@sha256:081f1bc7bd5e143dbb6e487b710bbc27712cdcfaced4c071b8e47349aa1b4171"
TEAM_OS_HEALTH_URL="http://127.0.0.1:3022/api/team-os/status"
TEAM_OS_READINESS_URL="http://127.0.0.1:3022/api/health?database=true&schema=true&ai=true"
TEAM_OS_VERSION_TARGET="/var/www/ai-team-os/updates/VERSION_CHECK.json"
