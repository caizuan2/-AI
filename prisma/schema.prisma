generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ConversationType {
  INGEST
  CHAT
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum KnowledgeSaveStrategy {
  MANUAL_CONFIRM
  AUTO_SAVE_AFTER_AI
  ANALYZE_ONLY
}

enum KnowledgeReviewStatus {
  NEEDS_REVIEW
  MASTERED
  EXPIRED
}

enum FeedbackType {
  ISSUE
  SUGGESTION
  BUG
  RAG_HELPFUL
  RAG_NOT_HELPFUL
}

enum FeedbackStatus {
  OPEN
  REVIEWING
  RESOLVED
  ARCHIVED
}

enum AnalyticsEventType {
  CHAT_QUESTION
  RAG_RETRIEVAL
  AI_CALL
  FILE_UPLOAD
}

enum LicenseKeyStatus {
  UNUSED
  USED
  DISABLED
}

enum UserRole {
  user
  kb_admin
  ingest_admin
  super_admin
  enterprise_admin
}

enum TenantPlan {
  free
  starter
  pro
  enterprise
}

enum TenantStatus {
  active
  inactive
  pending
  disabled
  archived
}

enum KnowledgeSource {
  user
  ingest
  system
}

enum LicenseStatus {
  active
  inactive
  expired
  revoked
}

model Tenant {
  id             String              @id @default(cuid())
  name           String
  plan           TenantPlan          @default(free)
  status         TenantStatus        @default(active)
  region         String              @default("global")
  seatLimit      Int                 @default(0) @map("seat_limit")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  users          User[]
  knowledgeItems KnowledgeItem[]
  ingestionJobs  IngestionJob[]
  queryLogs      KnowledgeQueryLog[]
  knowledge      Knowledge[]
  aiRequests     AIRequest[]
  licenses       License[]

  @@index([status])
  @@index([plan])
  @@map("tenants")
}

model User {
  id               String           @id @default(cuid())
  tenantId         String?          @map("tenant_id")
  email            String?          @unique
  phone            String           @unique
  passwordHash     String           @default("")
  name             String?
  isActive         Boolean          @default(true)
  licenseActivated Boolean          @default(false)
  role             UserRole         @default(user)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         Session[]
  redeemedLicenses LicenseKey[]     @relation("LicenseRedeemer")
  conversations    Conversation[]
  messages         Message[]
  knowledgeItems   KnowledgeItem[]
  settings         UserSettings?
  feedback         Feedback[]
  analyticsEvents  AnalyticsEvent[]
  roleAssignments  UserRoleAssignment[]
  auditLogs        AuditLog[]
  uploadedFiles    KnowledgeFile[]
  ingestionJobs    IngestionJob[]
  conversationPins UserConversationPin[]
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId], map: "users_tenant_id_idx")
  @@index([role])
  @@index([licenseActivated])
  @@index([isActive])
  @@map("users")
}

model Knowledge {
  id        String          @id @default(cuid())
  tenantId  String          @map("tenant_id")
  title     String
  content   String          @db.Text
  category  String          @default("general")
  summary   String          @default("") @db.Text
  source    KnowledgeSource @default(user)
  status    TenantStatus    @default(active)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId], map: "saas_knowledge_tenant_id_idx")
  @@index([source])
  @@index([status])
  @@index([createdAt], map: "saas_knowledge_created_at_idx")
  @@map("saas_knowledge")
}

model AIRequest {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  prompt    String   @db.Text
  response  String   @db.Text
  model     String   @default("gpt-4o-mini")
  tokens    Int      @default(0)
  status    String   @default("success")
  costUsd   Float    @default(0) @map("cost_usd")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId], map: "ai_requests_tenant_id_idx")
  @@index([userId], map: "ai_requests_user_id_idx")
  @@index([status])
  @@index([createdAt], map: "ai_requests_created_at_idx")
  @@map("ai_requests")
}

model License {
  id          String     @id @default(cuid())
  code        String     @unique
  key         String     @unique @default(cuid())
  type        String     @default("trial")
  status      String     @default("unused")
  plan        TenantPlan @default(free)
  userId      String?    @map("user_id")
  tenantId    String?    @map("tenant_id")
  expiresAt   DateTime?  @map("expires_at")
  activatedAt DateTime?  @map("activated_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([status])
  @@index([type])
  @@index([userId], map: "saas_licenses_user_id_idx")
  @@index([tenantId], map: "saas_licenses_tenant_id_idx")
  @@index([expiresAt], map: "saas_licenses_expires_at_idx")
  @@map("saas_licenses")
}

model UserRoleAssignment {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  role             UserRole  @default(user)
  assignedByUserId String?   @map("assigned_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  revokedAt        DateTime? @map("revoked_at")
  expiresAt        DateTime? @map("expires_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "user_role_assignments_user_id_idx")
  @@index([role])
  @@index([revokedAt], map: "user_role_assignments_revoked_at_idx")
  @@index([expiresAt], map: "user_role_assignments_expires_at_idx")
  @@map("user_role_assignments")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model LicenseKey {
  id               String           @id @default(cuid())
  keyHash          String           @unique
  status           LicenseKeyStatus @default(UNUSED)
  redeemedByUserId String?
  redeemedAt       DateTime?
  expiresAt        DateTime?
  createdAt        DateTime         @default(now())
  redeemedByUser   User?            @relation("LicenseRedeemer", fields: [redeemedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([status])
  @@index([redeemedByUserId])
  @@index([expiresAt])
  @@map("license_keys")
}

model ActivationLog {
  id        String   @id @default(cuid())
  codeHash  String
  userId    String
  success   Boolean
  message   String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([codeHash])
  @@index([userId])
  @@index([success])
  @@index([createdAt])
  @@map("activation_logs")
}

model UserSettings {
  id                String                @id @default(cuid())
  userId            String                @unique
  saveStrategy      KnowledgeSaveStrategy @default(MANUAL_CONFIRM)
  defaultExpireDays Int                   @default(90)
  preferredProvider String?
  preferredModel    String?
  ragTopK           Int?
  ragMinScore       Float?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([saveStrategy])
  @@map("user_settings")
}

model Conversation {
  id        String           @id @default(cuid())
  userId    String
  title     String
  type      ConversationType
  mode      String           @default("fast")
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  pins      UserConversationPin[]

  @@index([userId])
  @@index([type])
  @@index([updatedAt])
  @@map("conversations")
}

model UserConversationPin {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  conversationId String       @map("conversation_id")
  pinnedAt       DateTime     @default(now()) @map("pinned_at")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, conversationId], map: "user_conversation_pins_user_id_conversation_id_key")
  @@index([userId, pinnedAt], map: "user_conversation_pins_user_id_pinned_at_idx")
  @@map("user_conversation_pins")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?      @map("user_id")
  role           MessageRole
  content        String       @db.Text
  attachments    Json?
  sources        Json?
  metadata       Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([conversationId])
  @@index([userId], map: "messages_user_id_idx")
  @@index([createdAt])
  @@map("messages")
}

model KnowledgeItem {
  id                    String                          @id @default(cuid())
  userId                String
  tenantId              String?                         @map("tenant_id")
  title                 String
  content               String                          @db.Text
  summary               String                          @db.Text
  tags                  String[]                        @default([])
  category              String
  importance            Int
  clarityScore          Int                             @default(3)
  completenessScore     Int                             @default(3)
  usefulnessScore       Int                             @default(3)
  confidenceScore       Int                             @default(3)
  embedding             Json?
  embeddingModel        String?
  indexedAt             DateTime?                       @map("indexed_at")
  sourceType            String
  sourceId              String?
  sourceTitle           String?
  sourceUrl             String?
  sourceMessageId       String?
  expiresAt             DateTime?
  status                String                          @default("active")
  reviewStatus          KnowledgeReviewStatus           @default(NEEDS_REVIEW)
  lastReviewedAt        DateTime?
  nextReviewAt          DateTime?                       @default(now())
  deletedAt             DateTime?                       @map("deleted_at")
  deletedByUserId       String?                         @map("deleted_by")
  deleteReason          String?                         @map("delete_reason") @db.Text
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  user                  User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                Tenant?                         @relation(fields: [tenantId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  chunks                KnowledgeChunk[]
  ingestionJobs         IngestionJob[]
  mergeHistories        KnowledgeMergeHistory[]
  completionSuggestions KnowledgeCompletionSuggestion[]

  @@index([userId])
  @@index([tenantId], map: "knowledge_items_tenant_id_idx")
  @@index([category])
  @@index([importance])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status, expiresAt])
  @@index([tenantId, status, expiresAt], map: "knowledge_items_tenant_status_expires_idx")
  @@index([reviewStatus])
  @@index([nextReviewAt])
  @@index([userId, reviewStatus, nextReviewAt])
  @@index([tenantId, reviewStatus, nextReviewAt], map: "knowledge_items_tenant_review_next_idx")
  @@index([clarityScore, completenessScore, usefulnessScore, confidenceScore])
  @@index([embeddingModel])
  @@index([indexedAt])
  @@index([tenantId, indexedAt], map: "knowledge_items_tenant_indexed_at_idx")
  @@index([sourceType, sourceId])
  @@index([sourceType, sourceMessageId])
  @@index([deletedAt], map: "knowledge_items_deleted_at_idx")
  @@index([deletedByUserId], map: "knowledge_items_deleted_by_idx")
  @@index([updatedAt])
  @@map("knowledge_items")
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  role       UserRole?
  action     String
  targetType String    @map("target_type")
  targetId   String?   @map("target_id")
  ip         String?
  userAgent  String?   @map("user_agent")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId], map: "audit_logs_user_id_idx")
  @@index([role])
  @@index([action])
  @@index([targetType, targetId], map: "audit_logs_target_type_target_id_idx")
  @@index([createdAt], map: "audit_logs_created_at_idx")
  @@map("audit_logs")
}

model KnowledgeFile {
  id              String           @id @default(cuid())
  originalName    String           @map("original_name")
  fileType        String           @map("file_type")
  fileSize        Int              @map("file_size")
  storagePath     String           @map("storage_path")
  uploaderId      String           @map("uploader_id")
  status          String           @default("uploaded")
  categoryId      String?          @map("category_id")
  tags            String[]         @default([])
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  deletedByUserId String?          @map("deleted_by")
  deleteReason    String?          @map("delete_reason") @db.Text
  uploader        User             @relation(fields: [uploaderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  chunks          KnowledgeChunk[]
  ingestionJobs   IngestionJob[]

  @@index([uploaderId], map: "knowledge_files_uploader_id_idx")
  @@index([status])
  @@index([fileType], map: "knowledge_files_file_type_idx")
  @@index([deletedAt], map: "knowledge_files_deleted_at_idx")
  @@index([createdAt], map: "knowledge_files_created_at_idx")
  @@map("knowledge_files")
}

model IngestionJob {
  id                String         @id @default(cuid())
  sourceType        String         @map("source_type")
  sourceId          String?        @map("source_id")
  status            String         @default("pending")
  progress          Int            @default(0)
  errorMessage      String?        @map("error_message") @db.Text
  createdByUserId   String         @map("created_by")
  fileId            String?        @map("file_id")
  knowledgeItemId   String?        @map("knowledge_item_id")
  tenantId          String?        @map("tenant_id")
  metadata          Json?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  finishedAt        DateTime?      @map("finished_at")
  createdBy         User           @relation(fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tenant            Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  file              KnowledgeFile? @relation(fields: [fileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  knowledgeItem     KnowledgeItem? @relation(fields: [knowledgeItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([createdByUserId], map: "ingestion_jobs_created_by_idx")
  @@index([tenantId], map: "ingestion_jobs_tenant_id_idx")
  @@index([sourceType], map: "ingestion_jobs_source_type_idx")
  @@index([sourceId], map: "ingestion_jobs_source_id_idx")
  @@index([status])
  @@index([fileId], map: "ingestion_jobs_file_id_idx")
  @@index([knowledgeItemId], map: "ingestion_jobs_knowledge_item_id_idx")
  @@index([createdAt], map: "ingestion_jobs_created_at_idx")
  @@map("ingestion_jobs")
}

model KnowledgeMergeHistory {
  id                      String        @id @default(cuid())
  knowledgeItemId         String
  incomingTitle           String
  incomingSummary         String        @db.Text
  incomingContent         String        @db.Text
  incomingTags            String[]      @default([])
  incomingCategory        String
  incomingImportance      Int
  incomingSourceType      String
  incomingSourceTitle     String?
  incomingSourceUrl       String?
  incomingSourceMessageId String?
  createdAt               DateTime      @default(now())
  knowledgeItem           KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
  @@index([createdAt])
  @@map("knowledge_merge_histories")
}

model KnowledgeCompletionSuggestion {
  id              String        @id @default(cuid())
  knowledgeItemId String
  title           String
  detail          String        @db.Text
  question        String        @db.Text
  priority        Int
  mode            String        @default("local")
  model           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([knowledgeItemId])
  @@index([updatedAt])
  @@index([mode])
  @@map("knowledge_completion_suggestions")
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String
  type      FeedbackType
  content   String         @db.Text
  status    FeedbackStatus @default(OPEN)
  metadata  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("feedback")
}

model AnalyticsEvent {
  id           String             @id @default(cuid())
  userId       String?
  type         AnalyticsEventType
  numericValue Float?
  metadata     Json?
  occurredAt   DateTime           @default(now())
  createdAt    DateTime           @default(now())
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, occurredAt])
  @@index([type])
  @@index([type, occurredAt])
  @@index([occurredAt])
  @@map("analytics_events")
}

model KnowledgeQueryLog {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String?  @map("tenant_id")
  query        String   @db.Text
  providerUsed String
  modelUsed    String
  topK         Int
  latencyMs    Int
  tokenUsage   Json?
  cached       Boolean  @default(false)
  createdAt    DateTime @default(now())
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([tenantId], map: "knowledge_query_logs_tenant_id_idx")
  @@index([createdAt])
  @@index([cached])
  @@map("knowledge_query_logs")
}

model QuickActionCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  icon        String?
  type        String?
  action      String?
  prompt      String?  @db.Text
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([sortOrder])
  @@map("quick_action_categories")
}

model AiCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  value     Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("ai_cache")
}

model RateLimitEvent {
  id        String   @id @default(cuid())
  subject   String
  bucket    String
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subject, bucket])
  @@index([resetAt])
  @@map("rate_limit_events")
}

model KnowledgeChunk {
  id              String                       @id @default(cuid())
  knowledgeItemId String
  fileId          String?                      @map("file_id")
  chunkText       String                       @db.Text
  chunkIndex      Int
  summary         String?                      @db.Text
  tokenCount      Int?
  charCount       Int?
  contentHash     String?                      @map("content_hash")
  embeddingId     String?                      @map("embedding_id")
  embeddingModel  String?
  metadata        Json?
  /// pgvector is represented as Unsupported because Prisma Client does not natively support VECTOR.
  /// Write and search embeddings with raw SQL, for example via prisma.$queryRaw.
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime                     @default(now())
  knowledgeItem   KnowledgeItem                @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  file            KnowledgeFile?               @relation(fields: [fileId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([knowledgeItemId, chunkIndex])
  @@index([knowledgeItemId])
  @@index([fileId], map: "knowledge_chunks_file_id_idx")
  @@index([contentHash], map: "knowledge_chunks_content_hash_idx")
  @@map("knowledge_chunks")
}
