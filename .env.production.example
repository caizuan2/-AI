# AI Team OS production environment template.
# Copy this file to .env.production and inject real secrets outside Git.

NODE_ENV="production"
HOSTNAME="0.0.0.0"
PORT="3000"

# Public HTTPS origin used by browser sessions and Team OS same-origin calls.
NEXT_PUBLIC_APP_URL="https://team-os.example.com"
APP_URL="https://team-os.example.com"

# Runtime connection should use a pooled PostgreSQL URL when the provider offers one.
DATABASE_URL="postgresql://APP_USER:APP_PASSWORD@DB_HOST:5432/APP_DATABASE?sslmode=require&schema=public"
# Prisma migrate deploy should use the provider's direct connection URL.
DIRECT_URL="postgresql://MIGRATION_USER:MIGRATION_PASSWORD@DB_HOST:5432/APP_DATABASE?sslmode=require&schema=public"

AI_PROVIDER="qwen"
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"
# The current knowledge embedding pipeline requires OpenAI even when chat uses
# Qwen or DeepSeek.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# Generate independent high-entropy values; never reuse passwords or API keys.
SESSION_SECRET=""
# Compatibility name reserved by the Phase 12 production contract.
ENCRYPTION_KEY=""
# Legacy override for existing deployments. New deployments should leave this
# blank and use ENCRYPTION_KEY. If both exist, their values must be identical.
TEAM_OS_INTEGRATION_ENCRYPTION_KEY=""

# The root Web runtime is still a monolith. These existing-system secrets remain
# required when the corresponding login, license, admin, attachment, or cron paths
# are exposed by the same deployment.
LICENSE_SECRET=""
ADMIN_TOKEN=""
CRON_SECRET=""
NETLIFY_BLOBS_SITE_ID=""
NETLIFY_BLOBS_TOKEN=""

# Docker Compose interpolation. Bind to loopback when a reverse proxy/CDN is used.
TEAM_OS_IMAGE="ai-team-os:1.0.0"
TEAM_OS_BIND_ADDRESS="127.0.0.1"
TEAM_OS_PORT="3000"
