# Runtime: Netlify Functions / serverless Prisma Client.
# Must be the Supabase Transaction Pooler full URI, not a direct URL with only the port changed.
DATABASE_URL="postgresql://postgres.your-project-ref:your-url-encoded-db-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=30&pool_timeout=20&sslmode=require&schema=public"
# Migration: Prisma CLI / migrate deploy.
DIRECT_URL="postgresql://postgres:your-url-encoded-db-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require&schema=public"
# Optional for pnpm rag:reindex. The script uses REINDEX_DATABASE_URL || DIRECT_URL || DATABASE_URL.
REINDEX_DATABASE_URL=""
REINDEX_LIMIT=""
REINDEX_USER_ID=""
SESSION_SECRET="replace-with-a-long-random-session-secret"
LICENSE_SECRET="replace-with-a-long-random-license-secret"
ADMIN_TOKEN="replace-with-a-long-random-admin-token"
NETLIFY_BLOBS_SITE_ID="your-netlify-site-id"
NETLIFY_BLOBS_TOKEN="your-netlify-personal-access-token"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
QWEN_API_KEY="sk-your-qwen-api-key"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
AI_PROVIDER="qwen"
AI_FALLBACK_PROVIDER="openai"
AI_SECONDARY_FALLBACK_PROVIDER="deepseek"
# Compatibility aliases. Project-specific variables above take precedence.
LLM_PROVIDER=""
LLM_MODEL=""
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL=""
RAG_TOP_K="10"
RAG_MIN_SCORE="0.35"
RAG_SIMILARITY_THRESHOLD="0.35"
RAG_MAX_CONTEXT_CHUNKS="12"
RAG_MAX_CONTEXT_CHARS="12000"
RAG_ENABLE_RERANK="true"
RAG_CACHE_TTL_SECONDS="3600"
RATE_LIMIT_PER_USER_PER_MINUTE="20"
RATE_LIMIT_GLOBAL_PER_MINUTE="500"
INGEST_MAX_CHUNK_CHARS="1200"
INGEST_CHUNK_OVERLAP_CHARS="150"
INGEST_BATCH_SIZE="20"
OPENAI_CHAT_INPUT_COST_PER_1M="0.40"
OPENAI_CHAT_OUTPUT_COST_PER_1M="1.60"
OPENAI_EMBEDDING_COST_PER_1M="0.02"
JOBS_TIMEZONE="Asia/Shanghai"
CRON_SECRET="replace-with-a-random-string"
ADMIN_PHONES="+8613812345678"
ADMIN_USER_IDS=""
NODE_ENV="production"
NODE_VERSION="22"
